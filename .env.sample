# ----- app -----
APP_NAME=LangUp
ENV=local
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1
API_PREFIX=/api
BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=["http://localhost:3000"]

# ----- postgres -----
POSTGRES_USER=langup
POSTGRES_PASSWORD=langup
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=langup

# ----- redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme

# ----- jwt / auth -----
JWT_ACCESS_SECRET_KEY=change-me-access
JWT_REFRESH_SECRET_KEY=change-me-refresh
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ----- ai -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-8

# ----- object storage (s3 / minio) -----
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=langup
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ----- kafka -----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ----- payments -----
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
BLIK_MERCHANT_ID=
BLIK_API_KEY=
PAYMENTS_CURRENCY=USD
PAYMENTS_TRIAL_DAYS=7

# ----- email -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@langup.app

# ----- observability -----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
